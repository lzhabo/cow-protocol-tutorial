# CoW Swap Explorer — Environment Variables
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# All variables are optional — the app works with public endpoints by default.

# Set to "prod" to query mainnet/gnosis/arbitrum live data.
# Leave as "staging" (default) to use Sepolia testnet — safe for demos.
NEXT_PUBLIC_COW_ENV=staging
